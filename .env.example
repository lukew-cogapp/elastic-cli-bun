# Elasticsearch / OpenSearch connection
# Copy this file and fill in your credentials.
#
# Self-hosted:
# ES_HOST=https://localhost:9200
# ES_USER=elastic
# ES_PASSWORD=changeme
#
# Elastic Cloud:
# ES_CLOUD_ID=my-deployment:base64encodedstring
# ES_API_KEY=your-api-key
#
# OpenSearch:
# ES_HOST=https://opensearch.example.com:9200
# ES_USER=admin
# ES_PASSWORD=admin
